OPENAI_API_KEY=your-key-here
OPENAI_MODEL=gpt-4o
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/jobsearch

# "development" or "production" — controls cookie Secure/SameSite behavior.
ENVIRONMENT=development

# Frontend URL — where OAuth callbacks redirect after login.
FRONTEND_URL=http://localhost:5173

# Auth — generate with `openssl rand -hex 32`.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
OAUTH_SESSION_SECRET=

# OAuth provider credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# JSON array of emails allowed to access the admin panel.
ADMIN_EMAILS=["aparnaanand@outlook.com"]
